# ── Gemini ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_key_here

# ── Target (change to your Metasploitable VM IP) ─────────────────────
METASPLOITABLE_IP=192.168.56.101

# ── Local storage paths ───────────────────────────────────────────────
SQLITE_PATH=./arta.db
SESSIONS_TMP=/tmp/arta_sessions
SANDBOX_DIR=/tmp/arta_sandbox
NVD_JSON_PATH=./data/nvd_cve.json
EXPLOITDB_CSV=./data/exploitdb.csv

# ── Frontend ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Demo mode (true = use pre-recorded exploit fixtures) ─────────────
DEMO_MODE=false
